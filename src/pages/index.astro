---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <link
        slot="head"
        rel="preload"
        as="image"
        href="/images/shibuya.avif"
        imagesrcset="/images/shibuya-sm.avif 600w, /images/shibuya.avif 1200w"
        imagesizes="(max-width: 768px) 100vw, 60vw"
    />
    <div id="main-content-wrapper" class="w-full h-full">
        <section id="hero-section" class="relative min-h-[100svh] flex flex-col justify-center items-center pt-32 pb-10 overflow-hidden">
            <div class="relative z-10 max-w-7xl mx-auto px-6 text-center w-full">
                <h1 class="reveal-up font-black mb-10 tracking-tight lg:pt-16">
                    <span class="block text-3xl sm:text-5xl md:text-6xl lg:text-8xl mb-4 md:mb-8 text-transparent bg-clip-text bg-gradient-to-b from-white to-white/80">
                        あなたのインド生活に、
                    </span>
                    <span class="block text-[11vw] sm:text-6xl md:text-8xl lg:text-9xl text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 via-white to-rose-500 text-glow leading-tight pt-2 pb-2 break-keep">
                        日本のテレビを。
                    </span>
                </h1>
                <p class="reveal-up text-gray-400 text-sm md:text-lg max-w-2xl mx-auto mb-12 leading-loose break-words">
                    BBINFOならインドにいても<br class="hidden md:block">日本のテレビ(地上波、BS、CS)66チャンネルが楽しめます。<br>
                    VPN機能付きセットボックスだから<br class="hidden md:block">日本のNetflixやAmazon Prime、AbemaやTVerも視聴可能。<br><br>
                    <span class="text-white font-semibold text-[17px] md:text-xl">1週間の無料体験で、まずはお試しください。</span>
                </p>
                <div class="reveal-up flex flex-col md:flex-row gap-4 justify-center items-center">
                    <a id="hero-cta" href="/trial/" class="gradient-button inline-flex items-center justify-center rounded-full min-w-[132px] px-6 md:px-9 py-4 text-sm leading-[19px] font-medium text-white font-sans font-bold focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 hover:scale-105 transition-transform duration-300 whitespace-nowrap">
                        <span class="flex items-center gap-2">1週間の無料体験を申し込む <i class="ph-bold ph-lightning"></i></span>
                    </a>
                </div>

                <!-- Campaign banner -->
                <div class="reveal-up mt-10 flex flex-col items-center gap-5">
                    <div class="flex items-center gap-4 rounded-2xl px-6 py-4 w-full max-w-md" style="background: rgba(236,72,153,0.08); border: 1px solid rgba(236,72,153,0.25);">
                        <div class="text-3xl font-black text-pink-400 shrink-0">FREE</div>
                        <div class="text-left">
                            <div class="font-semibold text-white text-sm">ご契約者様限定、スマホ視聴アプリ無料開放。</div>
                            <div class="text-xs text-gray-500 mt-0.5">場所を選ばず、日本の放送をリアルタイムでお楽しみいただけます。追加費用は一切かかりません。</div>
                        </div>
                    </div>
                    <div class="flex gap-4">
                        <img src="/images/foot_download_ios.avif" alt="Download on the App Store" width="251" height="90" class="h-10 w-auto">
                        <img src="/images/foot_download_andr.avif" alt="Get it on Google Play" width="249" height="90" class="h-10 w-auto">
                    </div>
                </div>
            </div>
            <div class="absolute bottom-10 left-1/2 transform -translate-x-1/2 animate-bounce text-gray-500"><i class="ph ph-caret-down text-2xl"></i></div>
        </section>

        <section id="service_detail" class="pt-40 pb-24 px-6 relative">
            <div class="max-w-7xl mx-auto">
                <div class="text-center mb-16 reveal-up">
                    <h2 class="text-3xl md:text-5xl font-bold mb-4">選ばれる理由</h2>
                    <p class="text-gray-400">圧倒的な利便性と品質</p>
                </div>
                <div class="bento-grid grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-8 md:auto-rows-fr">
                    <a href="#feature-channels" class="col-span-1 md:col-span-2 row-span-2 reveal-up glass-panel p-0 rounded-3xl overflow-hidden group hover:border-white/20 transition-colors duration-500 min-h-[300px] block cursor-pointer">
                        <div class="relative h-full flex flex-col justify-end p-8">
                            <div class="absolute top-0 right-0 w-full h-full z-0">
                                <img
                                    src="/images/shibuya.avif"
                                    srcset="/images/shibuya-sm.avif 600w, /images/shibuya.avif 1200w"
                                    sizes="(max-width: 768px) 100vw, 60vw"
                                    alt="Tokyo Neon Night"
                                    width="800"
                                    height="600"
                                    loading="eager"
                                    fetchpriority="high"
                                    decoding="sync"
                                    class="w-full h-full object-cover opacity-30 group-hover:scale-110 transition-transform duration-700"
                                    onerror="this.removeAttribute('srcset')"
                                >
                                <div class="absolute inset-0 bg-gradient-to-t from-black via-black/50 to-transparent"></div>
                            </div>
                            <div class="relative z-10 h-full flex flex-col justify-end">
                                <div class="w-12 h-12 bg-black/90 rounded-xl flex items-center justify-center mb-4 border border-white/10"><i class="ph-fill ph-television text-2xl text-cyan-400"></i></div>
                                <h3 class="text-2xl md:text-3xl font-bold mb-2">地上波・BS・CS 66局</h3>
                                <p class="text-gray-300 mb-4 text-sm md:text-base">日本の主要チャンネルを完全網羅。リアルタイム視聴はもちろん、30分のタイムシフト機能で「今」を見逃しません。</p>
                                <div class="flex flex-wrap gap-2 text-xs font-mono text-cyan-300">
                                    <span class="px-2 py-1 bg-cyan-900/30 rounded border border-cyan-500/30">NHK</span><span class="px-2 py-1 bg-cyan-900/30 rounded border border-cyan-500/30">日テレ</span><span class="px-2 py-1 bg-cyan-900/30 rounded border border-cyan-500/30">テレ朝</span><span class="px-2 py-1 bg-cyan-900/30 rounded border border-cyan-500/30">TBS</span><span class="px-2 py-1 bg-cyan-900/30 rounded border border-cyan-500/30">フジ</span><span class="px-2 py-1 bg-cyan-900/30 rounded border border-cyan-500/30">WOWOW</span><span class="px-2 py-1 bg-cyan-900/30 rounded border border-cyan-500/30">J SPORTS</span><span class="px-2 py-1 bg-cyan-900/30 rounded border border-cyan-500/30">アニマックス</span><span class="px-2 py-1 bg-cyan-900/30 rounded border border-cyan-500/30">ディズニー</span>
                                </div>
                            </div>
                        </div>
                    </a>
                    <a href="#feature-allrec" class="glass-panel p-8 rounded-3xl reveal-up flex flex-col justify-between hover:border-white/20 transition-colors duration-500 min-h-[200px] cursor-pointer" style="transition-delay: 100ms;">
                        <i class="ph-fill ph-clock-counter-clockwise text-4xl text-purple-400 mb-4"></i>
                        <div><h3 class="text-xl font-bold mb-2">4週間見逃し視聴</h3><p class="text-sm text-gray-400">忙しいあなたへ。過去4週間分の全番組をクラウドに保存。いつでも好きな時に再生可能です。</p></div>
                    </a>
                    <a href="#feature-stb" class="glass-panel p-8 rounded-3xl reveal-up flex flex-col justify-between hover:border-white/20 transition-colors duration-500 min-h-[200px] cursor-pointer" style="transition-delay: 200ms;">
                        <i class="ph-fill ph-globe-hemisphere-east text-4xl text-green-400 mb-4"></i>
                        <div><h3 class="text-xl font-bold mb-2">VPN機能付きセットボックス</h3><p class="text-sm text-gray-400">面倒な設定は不要。Netflix, Amazon Prime, Abemaも日本と同じ環境で楽しめます。</p><p class="text-[10px] text-gray-600 mt-2">*別途各サービスの契約が必要です</p></div>
                    </a>
                    <a href="#feature-mobile" class="col-span-1 glass-panel p-8 rounded-3xl reveal-up flex flex-col justify-between hover:border-white/20 transition-colors duration-500 min-h-[200px] cursor-pointer">
                        <i class="ph-fill ph-device-mobile-camera text-4xl text-pink-500 mb-4"></i>
                        <div><h3 class="text-xl font-bold mb-2">スマートフォン</h3><p class="text-sm text-gray-400">専用アプリで、移動中や外出先でも快適に日本のテレビを楽しめます。</p></div>
                    </a>
                    <div class="col-span-1 md:col-span-2 glass-panel p-8 rounded-3xl reveal-up hover:border-white/20 transition-colors duration-500 relative overflow-hidden min-h-[200px]">
                        <div class="absolute -right-20 -bottom-20 w-64 h-64 bg-cyan-500/20 rounded-full blur-3xl pointer-events-none"></div>
                        <div class="flex flex-col md:flex-row items-center gap-8 relative z-10 h-full">
                            <div class="flex-1">
                                <h3 class="text-xl md:text-2xl font-bold mb-2">ストレスフリーな視聴体験</h3>
                                <p class="text-gray-400">専用機器をテレビとネットにつなぐだけ。面倒な設定はありません。</p>
                            </div>
                            <div class="flex-1 grid grid-cols-3 gap-4 w-full relative z-10">
                                <div class="text-center p-2 md:p-4 rounded-2xl bg-white/5 border border-white/5"><div class="text-xl md:text-2xl font-bold text-cyan-400 mb-1">HD</div><div class="text-[8px] md:text-[10px] text-gray-500 uppercase tracking-widest">Quality</div></div>
                                <div class="text-center p-2 md:p-4 rounded-2xl bg-white/5 border border-white/5"><div class="text-xl md:text-2xl font-bold text-cyan-400 mb-1">0s</div><div class="text-[8px] md:text-[10px] text-gray-500 uppercase tracking-widest">Lag Free</div></div>
                                <div class="text-center p-2 md:p-4 rounded-2xl bg-white/5 border border-white/5"><div class="text-xl md:text-2xl font-bold text-cyan-400 mb-1">JP</div><div class="text-[8px] md:text-[10px] text-gray-500 uppercase tracking-widest">日本語サポート</div></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ==================== FEATURE DETAIL SECTIONS ==================== -->

        <!-- 01 ── チャンネル数と臨場感 -->
        <section id="feature-channels" class="py-28 md:py-40 px-6 relative overflow-hidden border-t border-white/5 backdrop-blur-sm" style="background: rgba(3,3,3,0.55);">
            <div class="absolute top-0 right-0 w-[600px] h-[600px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(0,243,255,0.04) 0%, transparent 65%);"></div>
            <div class="max-w-7xl mx-auto">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 lg:items-stretch">

                    <!-- Text (left) -->
                    <div class="reveal-up">
                        <div class="flex items-end gap-4 mb-8">
                            <span class="text-[80px] font-black leading-none text-cyan-400/10 select-none" aria-hidden="true">01</span>
                            <div class="pb-3 flex-1 h-px bg-gradient-to-r from-cyan-400/20 to-transparent"></div>
                        </div>
                        <div class="inline-flex items-center gap-2 bg-cyan-400/10 border border-cyan-400/20 rounded-full px-3 py-1 mb-6">
                            <span class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse" aria-hidden="true"></span>
                            <span class="text-cyan-400 text-xs font-semibold tracking-widest uppercase">LIVE STREAMING</span>
                        </div>
                        <h2 class="text-4xl md:text-5xl lg:text-6xl font-black mb-6 leading-tight">
                            圧倒的な<br><span class="text-cyan-400">チャンネル数</span>と<br>臨場感
                        </h2>
                        <p class="text-gray-400 text-lg leading-relaxed mb-4">地上波・BS・CS 全66局を網羅。ニュース、バラエティ、ドラマはもちろん、熱狂のスポーツ中継や最新アニメまで、日本国内と変わらぬ臨場感でリアルタイムに楽しめます。</p>
                        <p class="text-gray-400 leading-relaxed mb-10">さらに、最大30分前まで遡れる「追っかけ再生機能」を搭載。不意の外出や用事で冒頭を見逃しても、ワンタッチで開始時間に巻き戻し、「今」の興奮を余さず共有できます。</p>
                        <!-- Stats -->
                        <div class="grid grid-cols-4 gap-3 mb-8">
                            <div class="glass-panel rounded-2xl p-4 text-center">
                                <div class="text-3xl font-black text-cyan-400">28</div>
                                <div class="text-[10px] text-gray-500 uppercase tracking-widest mt-1">地上波</div>
                            </div>
                            <div class="glass-panel rounded-2xl p-4 text-center">
                                <div class="text-3xl font-black text-purple-400">21</div>
                                <div class="text-[10px] text-gray-500 uppercase tracking-widest mt-1">BS</div>
                            </div>
                            <div class="glass-panel rounded-2xl p-4 text-center">
                                <div class="text-3xl font-black text-pink-400">17</div>
                                <div class="text-[10px] text-gray-500 uppercase tracking-widest mt-1">CS</div>
                            </div>
                            <div class="glass-panel rounded-2xl p-4 text-center">
                                <div class="text-3xl font-black text-white">66</div>
                                <div class="text-[10px] text-gray-500 uppercase tracking-widest mt-1">TOTAL</div>
                            </div>
                        </div>
                        <!-- Timeshift callout -->
                        <div class="flex items-center gap-4 glass-panel rounded-2xl p-5">
                            <div class="w-12 h-12 rounded-xl bg-cyan-400/10 flex items-center justify-center shrink-0">
                                <i class="ph-fill ph-rewind-circle text-2xl text-cyan-400"></i>
                            </div>
                            <div>
                                <div class="font-semibold text-white mb-0.5">追っかけ再生機能</div>
                                <div class="text-sm text-gray-500">最大30分前まで巻き戻し可能。見逃しゼロ。</div>
                            </div>
                        </div>
                    </div>

                    <!-- Visual (right) — EPG Guide -->
                    <div class="reveal-up flex flex-col lg:pt-[10.5rem]" style="transition-delay: 150ms;">
                        <div class="glass-panel rounded-3xl overflow-hidden flex-1 flex flex-col">
                            <!-- Guide header -->
                            <div class="flex items-center justify-between px-5 py-3.5 border-b border-white/5" style="background: rgba(0,243,255,0.03);">
                                <div class="flex items-center gap-2">
                                    <span class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse" aria-hidden="true"></span>
                                    <span class="text-xs font-bold text-cyan-400 uppercase tracking-widest">LIVE TV GUIDE</span>
                                </div>
                                <div class="flex items-center gap-3">
                                    <span class="text-xs text-gray-600 tabular-nums">19:24</span>
                                    <span class="text-[10px] text-gray-600 px-2 py-0.5 rounded-md bg-white/5 border border-white/5">全 66ch</span>
                                </div>
                            </div>
                            <!-- Time header -->
                            <div class="flex text-[9px] text-gray-700 uppercase tracking-wider border-b border-white/[0.04]">
                                <div class="w-[88px] shrink-0 px-3 py-2 border-r border-white/[0.04]"></div>
                                <div class="flex-1 grid grid-cols-4 divide-x divide-white/[0.04]">
                                    <div class="px-3 py-2">18:00</div>
                                    <div class="px-3 py-2">19:00</div>
                                    <div class="px-3 py-2">20:00</div>
                                    <div class="px-3 py-2">21:00</div>
                                </div>
                            </div>
                            <!-- Channel rows -->
                            <div class="divide-y divide-white/[0.04]">
                                <!-- NHK総合 -->
                                <div class="flex items-stretch text-[10px]">
                                    <div class="w-[88px] shrink-0 px-3 py-2.5 flex items-center gap-1.5 border-r border-white/[0.04]">
                                        <span class="text-cyan-400/50 font-mono text-[9px]">1</span>
                                        <span class="text-gray-400 truncate">NHK総合</span>
                                    </div>
                                    <div class="flex-1 flex divide-x divide-white/[0.03]">
                                        <div class="flex-1 px-2 py-2.5 bg-cyan-400/5"><span class="text-cyan-300 truncate block">ニュース7</span></div>
                                        <div class="flex-1 px-2 py-2.5"><span class="text-gray-500 truncate block">クローズアップ現代</span></div>
                                        <div class="flex-[2] px-2 py-2.5 bg-cyan-400/[0.04]"><span class="text-cyan-400/70 truncate block">NHKスペシャル</span></div>
                                        <div class="flex-1 px-2 py-2.5"><span class="text-gray-500 truncate block">ニュース9</span></div>
                                    </div>
                                </div>
                                <!-- 日本テレビ -->
                                <div class="flex items-stretch text-[10px]">
                                    <div class="w-[88px] shrink-0 px-3 py-2.5 flex items-center gap-1.5 border-r border-white/[0.04]">
                                        <span class="text-purple-400/50 font-mono text-[9px]">4</span>
                                        <span class="text-gray-400 truncate">日本テレビ</span>
                                    </div>
                                    <div class="flex-1 flex divide-x divide-white/[0.03]">
                                        <div class="flex-[1.5] px-2 py-2.5"><span class="text-gray-500 truncate block">夕方ニュース</span></div>
                                        <div class="flex-[3] px-2 py-2.5 bg-purple-400/5"><span class="text-purple-300 truncate block">ダウンタウンDX</span></div>
                                        <div class="flex-[2] px-2 py-2.5 bg-yellow-400/5"><span class="text-yellow-400/70 truncate block">ドラマ</span></div>
                                    </div>
                                </div>
                                <!-- TBSテレビ -->
                                <div class="flex items-stretch text-[10px]">
                                    <div class="w-[88px] shrink-0 px-3 py-2.5 flex items-center gap-1.5 border-r border-white/[0.04]">
                                        <span class="text-yellow-400/50 font-mono text-[9px]">6</span>
                                        <span class="text-gray-400 truncate">TBSテレビ</span>
                                    </div>
                                    <div class="flex-1 flex divide-x divide-white/[0.03]">
                                        <div class="flex-1 px-2 py-2.5 bg-cyan-400/5"><span class="text-cyan-300 truncate block">JNNニュース</span></div>
                                        <div class="flex-[2.5] px-2 py-2.5 bg-purple-400/5"><span class="text-purple-300 truncate block">バラエティ</span></div>
                                        <div class="flex-[2.5] px-2 py-2.5 bg-yellow-400/5"><span class="text-yellow-400/70 truncate block">金曜ドラマ</span></div>
                                    </div>
                                </div>
                                <!-- テレビ朝日 -->
                                <div class="flex items-stretch text-[10px]">
                                    <div class="w-[88px] shrink-0 px-3 py-2.5 flex items-center gap-1.5 border-r border-white/[0.04]">
                                        <span class="text-cyan-400/50 font-mono text-[9px]">5</span>
                                        <span class="text-gray-400 truncate">テレビ朝日</span>
                                    </div>
                                    <div class="flex-1 flex divide-x divide-white/[0.03]">
                                        <div class="flex-[2] px-2 py-2.5 bg-cyan-400/5"><span class="text-cyan-300 truncate block">報道ステーション</span></div>
                                        <div class="flex-[4] px-2 py-2.5 bg-purple-400/5"><span class="text-purple-300 truncate block">アメトーーク！</span></div>
                                        <div class="flex-[2] px-2 py-2.5"><span class="text-gray-500 truncate block">ニュース</span></div>
                                    </div>
                                </div>
                                <!-- フジテレビ -->
                                <div class="flex items-stretch text-[10px]">
                                    <div class="w-[88px] shrink-0 px-3 py-2.5 flex items-center gap-1.5 border-r border-white/[0.04]">
                                        <span class="text-green-400/50 font-mono text-[9px]">8</span>
                                        <span class="text-gray-400 truncate">フジテレビ</span>
                                    </div>
                                    <div class="flex-1 flex divide-x divide-white/[0.03]">
                                        <div class="flex-[2] px-2 py-2.5"><span class="text-gray-500 truncate block">FNNニュース</span></div>
                                        <div class="flex-[6] px-2 py-2.5 bg-green-400/5"><span class="text-green-300 truncate block">⚽ サッカー日本代表 LIVE中継</span></div>
                                    </div>
                                </div>
                                <!-- テレビ東京 -->
                                <div class="flex items-stretch text-[10px]">
                                    <div class="w-[88px] shrink-0 px-3 py-2.5 flex items-center gap-1.5 border-r border-white/[0.04]">
                                        <span class="text-pink-400/50 font-mono text-[9px]">7</span>
                                        <span class="text-gray-400 truncate">テレビ東京</span>
                                    </div>
                                    <div class="flex-1 flex divide-x divide-white/[0.03]">
                                        <div class="flex-1 px-2 py-2.5 bg-pink-400/5"><span class="text-pink-300 truncate block">アニメ</span></div>
                                        <div class="flex-[2] px-2 py-2.5"><span class="text-gray-500 truncate block">ガイアの夜明け</span></div>
                                        <div class="flex-[2] px-2 py-2.5 bg-cyan-400/5"><span class="text-cyan-300 truncate block">WBS</span></div>
                                        <div class="flex-[2] px-2 py-2.5 bg-pink-400/5"><span class="text-pink-300 truncate block">深夜アニメ</span></div>
                                    </div>
                                </div>
                                <!-- WOWOW -->
                                <div class="flex items-stretch text-[10px]">
                                    <div class="w-[88px] shrink-0 px-3 py-2.5 flex items-center gap-1.5 border-r border-white/[0.04]">
                                        <span class="text-blue-400/50 font-mono text-[9px]">BS</span>
                                        <span class="text-gray-400 truncate">WOWOW</span>
                                    </div>
                                    <div class="flex-1 flex divide-x divide-white/[0.03]">
                                        <div class="flex-[4] px-2 py-2.5 bg-blue-400/5"><span class="text-blue-300 truncate block">🎬 映画 ミッション：インポッシブル</span></div>
                                        <div class="flex-[4] px-2 py-2.5 bg-blue-400/[0.04]"><span class="text-blue-400/60 truncate block">映画 トップガン</span></div>
                                    </div>
                                </div>
                                <!-- J SPORTS -->
                                <div class="flex items-stretch text-[10px]">
                                    <div class="w-[88px] shrink-0 px-3 py-2.5 flex items-center gap-1.5 border-r border-white/[0.04]">
                                        <span class="text-green-400/50 font-mono text-[9px]">CS</span>
                                        <span class="text-gray-400 truncate">J SPORTS</span>
                                    </div>
                                    <div class="flex-1 px-2 py-2.5 bg-green-400/5">
                                        <span class="text-green-300 truncate block">🏀 バスケットボール 日本 vs USA LIVE</span>
                                    </div>
                                </div>
