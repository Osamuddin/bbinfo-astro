---
const shapes = [
  { width: 600, height: 140, top: '12%',  left: '-8%',  rotate: -15, delay: 0.2 },
  { width: 500, height: 120, top: '68%',  left: '55%',  rotate:  15, delay: 0.4 },
  { width: 320, height:  80, top: '38%',  left: '72%',  rotate: -10, delay: 0.6 },
  { width: 200, height:  60, top: '58%',  left: '2%',   rotate:  20, delay: 0.8 },
  { width: 420, height: 100, top: '22%',  left: '38%',  rotate:  -5, delay: 1.0 },
];
---

<div style="position:fixed;top:0;left:0;width:100%;height:100vh;z-index:-1;overflow:hidden;pointer-events:none;">
  <div class="bg-blur-gradient"></div>
  {shapes.map((s) => (
    <div
      class="shape-wrapper"
      style={`width:${s.width}px;height:${s.height}px;top:${s.top};left:${s.left};--rot-start:${s.rotate - 8}deg;--rot-end:${s.rotate}deg;animation-delay:${s.delay}s;`}
    >
      <div class="shape-float">
        <div class="shape-content"></div>
      </div>
    </div>
  ))}
</div>
