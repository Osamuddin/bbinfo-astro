---
// src/layouts/Layout.astro
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

import ElegantShape from '../components/ElegantShape.astro';
---

<!doctype html>
<html lang="ja" class="scroll-smooth">
    <head>
        <script is:inline>
          // dataLayer だけ即時初期化（GTM ロード前のイベントをキュー保持）
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({'gtm.start': new Date().getTime(), event: 'gtm.js'});
        </script>

        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="description" content="インドで日本のテレビ（地上波・BS・CS 66チャンネル）が見られるBBINFO。VPN機能付きセットボックスでNetflix・Amazon Prime・AbemaやTVerも日本と同じ環境で視聴可能。1週間の無料体験受付中。" />
        <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
        <link rel="icon" href="/favicon.ico" sizes="32x32" />

        <slot name="head" />

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

        <link
            href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&family=Inter:wght@400;600&display=optional"
            rel="stylesheet"
            media="print"
            onload="this.media='all'"
        >

        <noscript>
            <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&family=Inter:wght@400;600&display=optional" rel="stylesheet">
        </noscript>
        <link rel="stylesheet" href="/fonts/phosphor/icons.css" media="print" onload="this.media='all'" />
        <noscript><link rel="stylesheet" href="/fonts/phosphor/icons.css" /></noscript>

        <title>BBINFO | インドで日本のテレビを見るなら</title>
    </head>
    
    <body class="antialiased selection:bg-cyan-500 selection:text-white bg-[#030303] text-white">
        <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-T8FBH9BZ"
        height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

        <ElegantShape />
        
        <div class="hero-geometric-bg">
        </div>

        <Header />

        <main class="relative w-full overflow-x-hidden">
            <slot />
        </main>
        
        <Footer />

        <script is:inline>
          if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
              navigator.serviceWorker.register('/sw.js');
            });
          }
        </script>

        <script is:inline>
          // GTM・Clarity をユーザーの最初のインタラクション or idle 時に遅延ロード
          var _analyticsLoaded = false;
          function loadAnalytics() {
            if (_analyticsLoaded) return;
            _analyticsLoaded = true;

            // GTM
            (function(w,d,s,l,i){
              var f=d.getElementsByTagName(s)[0],
                  j=d.createElement(s),
                  dl=l!='dataLayer'?'&l='+l:'';
              j.async=true;
              j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;
              f.parentNode.insertBefore(j,f);
            })(window,document,'script','dataLayer','GTM-T8FBH9BZ');

            // Clarity
            (function(c,l,a,r,i,t,y){
              c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
              t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
              y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
            })(window,document,"clarity","script","v5rvk99mct");
          }

          // 最初のユーザーインタラクションで即ロード
          var _events = ['mousemove','keydown','scroll','touchstart','click'];
          function onFirstInteraction() {
            _events.forEach(function(e){ window.removeEventListener(e, onFirstInteraction); });
            loadAnalytics();
          }
          _events.forEach(function(e){ window.addEventListener(e, onFirstInteraction, {once:true, passive:true}); });

          // インタラクションがなくても 5 秒後にロード
          setTimeout(loadAnalytics, 5000);
        </script>
    </body>
</html>